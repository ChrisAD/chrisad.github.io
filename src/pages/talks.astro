---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import TalkList from '../components/TalkList.astro';

const talks = (await getCollection('talks')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const groups = [
  { type: 'talk', heading: 'Talks & presentations' },
  { type: 'podcast', heading: 'Podcasts' },
  { type: 'webinar', heading: 'Webcasts' },
  { type: 'tv', heading: 'TV appearances' },
  { type: 'article', heading: 'Articles & press' },
  { type: 'video', heading: 'Video series' },
] as const;

const present = groups.filter((g) => talks.some((t) => t.data.type === g.type));
---

<Base
  title="Talks & media"
  description="Conference talks, podcasts, webcasts, TV appearances, and articles featuring Chris Dale."
>
  <h1 class="rule-heading">Talks &amp; media</h1>

  <div class="chips" data-filter="talks">
    <button type="button" class="chip is-active" data-value="all">all</button>
    {present.map((g) => <button type="button" class="chip" data-value={g.type}>{g.heading.toLowerCase()}</button>)}
  </div>

  {
    present.map((group) => (
      <section data-type={group.type}>
        <h2 class="rule-heading">{group.heading}</h2>
        <TalkList talks={talks.filter((t) => t.data.type === group.type)} />
      </section>
    ))
  }

  <script>
    const bar = document.querySelector('[data-filter="talks"]');
    const sections = document.querySelectorAll('section[data-type]');
    bar?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.chip');
      if (!btn) return;
      const value = btn.getAttribute('data-value');
      bar.querySelectorAll('.chip').forEach((c) => c.classList.toggle('is-active', c === btn));
      sections.forEach((s) => {
        (s as HTMLElement).hidden = value !== 'all' && s.getAttribute('data-type') !== value;
      });
    });
  </script>
</Base>
