---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const videos = (await getCollection('videos')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const years = [...new Set(videos.map((v) => v.data.date.getFullYear()))];

const tagCounts = new Map<string, number>();
for (const v of videos) for (const t of v.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const tags = [...tagCounts.entries()].filter(([, n]) => n >= 2).sort((a, b) => b[1] - a[1]).map(([t]) => t);

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Base
  title="Videos"
  description="Video archive: web hacking tutorials, OverTheWire Natas walkthroughs, tooling tips, and more from Chris Dale's YouTube channel."
>
  <h1 class="rule-heading">Videos</h1>
  <p>
    Tutorials and walkthroughs from <a href="https://www.youtube.com/c/chrisdale">my YouTube channel</a>:
    the full
    <a href="https://www.youtube.com/watch?v=FLUMQfOD4Lw&list=PLag7W-lJE2Aw8hzezQl17ZlE6CfNS3nYu">OverTheWire Natas web security series</a>,
    the <a href="https://www.youtube.com/playlist?list=PLag7W-lJE2Aw4m1754iJd3tQlgnr4eAeQ">bookshelf reviews</a>,
    Burp Suite tips, PowerShell, penetration test methodology, and more.
  </p>

  <div class="chips" data-filter="videos">
    <button type="button" class="chip is-active" data-value="all">all</button>
    {tags.map((tag) => <button type="button" class="chip" data-value={tag}>#{tag}</button>)}
  </div>

  {
    years.map((year) => (
      <section data-year={year}>
        <h2 class="rule-heading">{year}</h2>
        <ul class="item-list">
          {videos
            .filter((v) => v.data.date.getFullYear() === year)
            .map((video) => (
              <li data-tags={video.data.tags.join(' ')}>
                <time datetime={video.data.date.toISOString()}>{fmt(video.data.date)}</time>
                <span class="title">
                  <a href={`/videos/${video.id}/`}>{video.data.title}</a>
                </span>
              </li>
            ))}
        </ul>
      </section>
    ))
  }

  <script>
    const bar = document.querySelector('[data-filter="videos"]');
    const sections = document.querySelectorAll('section[data-year]');
    bar?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.chip');
      if (!btn) return;
      const value = btn.getAttribute('data-value');
      bar.querySelectorAll('.chip').forEach((c) => c.classList.toggle('is-active', c === btn));
      sections.forEach((section) => {
        let visible = 0;
        section.querySelectorAll<HTMLElement>('li[data-tags]').forEach((li) => {
          const show = value === 'all' || li.getAttribute('data-tags')!.split(' ').includes(value!);
          li.hidden = !show;
          if (show) visible++;
        });
        (section as HTMLElement).hidden = visible === 0;
      });
    });
  </script>
</Base>
