---
import Base from './Base.astro';

const { frontmatter } = Astro.props;
---

<Base title={frontmatter.title} description={frontmatter.description}>
  <h1 class="rule-heading">{frontmatter.title}</h1>
  {frontmatter.updated && <p class="post-meta">Last updated {frontmatter.updated}</p>}
  <article class="prose">
    <slot />
  </article>
</Base>
