---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const SITE_TITLE = 'Chris Dale';
const SITE_DESCRIPTION =
  'Offensive security, incident response, and attack surface management. Co-founder & Chief Hacking Officer at River Security, SANS Principal Instructor.';

const { title, description = SITE_DESCRIPTION, ogImage } = Astro.props;
const pageTitle = title ? `${title} · chrisdale.no` : `${SITE_TITLE} · chrisdale.no`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site) : undefined;

const nav = [
  { href: '/posts/', label: 'posts' },
  { href: '/talks/', label: 'talks' },
  { href: '/videos/', label: 'videos' },
  { href: '/whoami/', label: 'whoami' },
  { href: '/contact/', label: 'contact' },
];
const current = Astro.url.pathname;

const [postsCol, talksCol, videosCol] = await Promise.all([
  getCollection('posts', ({ data }) => import.meta.env.DEV || !data.draft),
  getCollection('talks'),
  getCollection('videos'),
]);

const randomVideos = videosCol.map((v) => ({ id: v.data.youtubeId, title: v.data.title }));

const paletteItems = [
  { t: 'Home', u: '/', k: 'page' },
  { t: 'Posts', u: '/posts/', k: 'page' },
  { t: 'Talks & media', u: '/talks/', k: 'page' },
  { t: 'Videos', u: '/videos/', k: 'page' },
  { t: 'Tags', u: '/tags/', k: 'page' },
  { t: 'whoami', u: '/whoami/', k: 'page' },
  { t: 'Now', u: '/now/', k: 'page' },
  { t: 'Contact', u: '/contact/', k: 'page' },
  { t: 'Search everything', u: '/search/', k: 'page' },
  ...postsCol
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .map((p) => ({ t: p.data.title, u: `/posts/${p.id}/`, k: 'post' })),
  ...videosCol.map((v) => ({ t: v.data.title, u: `/videos/${v.id}/`, k: 'video' })),
  ...talksCol.map((t) => ({ t: t.data.title, u: t.data.url ?? '/talks/', k: 'talk' })),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/"><span class="block">█</span> chrisdale.no</a>
        <nav class="site-nav">
          {
            nav.map((item) => (
              <a href={item.href} aria-current={current.startsWith(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
          <button type="button" id="palette-btn" class="random-btn" title="Search (Ctrl-K)">search ⌘K</button>
          <button type="button" id="random-video-btn" class="random-btn">🎲 random Chris</button>
        </nav>
      </div>
    </header>

    <div id="video-modal" class="video-modal" hidden>
      <div class="video-modal-backdrop" data-close></div>
      <div class="video-modal-inner" role="dialog" aria-modal="true" aria-label="Random video">
        <div class="video-modal-bar">
          <span id="video-modal-title" class="video-modal-title"></span>
          <span class="video-modal-actions">
            <button type="button" id="random-video-again" class="random-btn">🎲 another</button>
            <button type="button" class="random-btn" data-close aria-label="Close">✕</button>
          </span>
        </div>
        <div class="video-embed" id="video-modal-frame"></div>
      </div>
    </div>

    <div id="palette" class="palette" hidden>
      <div class="palette-backdrop" data-palette-close></div>
      <div class="palette-box" role="dialog" aria-modal="true" aria-label="Command palette">
        <input
          id="palette-input"
          class="palette-input"
          type="text"
          placeholder="Jump to a post, talk, video, or page…"
          autocomplete="off"
          spellcheck="false"
        />
        <ul id="palette-results" class="palette-results"></ul>
      </div>
    </div>

    <script type="application/json" id="random-video-data" set:html={JSON.stringify(randomVideos)} />
    <script type="application/json" id="palette-data" set:html={JSON.stringify(paletteItems)} />

    <main class="wrap" data-pagefind-body>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span>© {new Date().getFullYear()} Chris Dale</span>
        <span>
          <a href="/now/">now</a> · <a href="/search/">search</a> ·
          <a href="/rss.xml">rss</a> · <a href="https://riversecurity.eu/">river security</a>
        </span>
      </div>
    </footer>

    <script>
      // ── random video ──────────────────────────────
      const videos = JSON.parse(document.getElementById('random-video-data')?.textContent || '[]');
      const modal = document.getElementById('video-modal')!;
      const frame = document.getElementById('video-modal-frame')!;
      const titleEl = document.getElementById('video-modal-title')!;
      let last = -1;

      function pickVideo() {
        if (videos.length === 0) return;
        let i = Math.floor(Math.random() * videos.length);
        if (videos.length > 1 && i === last) i = (i + 1) % videos.length;
        last = i;
        const v = videos[i];
        titleEl.textContent = v.title;
        frame.innerHTML =
          '<iframe src="https://www.youtube-nocookie.com/embed/' +
          encodeURIComponent(v.id) +
          '?autoplay=1&rel=0" title="' +
          v.title.replace(/"/g, '&quot;') +
          '" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>';
      }
      function openVideo() {
        pickVideo();
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
      }
      function closeVideo() {
        modal.hidden = true;
        frame.innerHTML = '';
        document.body.style.overflow = '';
      }
      document.getElementById('random-video-btn')?.addEventListener('click', openVideo);
      document.getElementById('random-video-again')?.addEventListener('click', pickVideo);
      modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeVideo));

      // ── command palette ───────────────────────────
      const items = JSON.parse(document.getElementById('palette-data')?.textContent || '[]');
      const palette = document.getElementById('palette')!;
      const input = document.getElementById('palette-input') as HTMLInputElement;
      const results = document.getElementById('palette-results')!;
      let active = 0;
      let matches: any[] = [];

      function render() {
        const q = input.value.trim().toLowerCase();
        matches = (q ? items.filter((it: any) => it.t.toLowerCase().includes(q)) : items).slice(0, 8);
        active = 0;
        results.innerHTML = matches
          .map(
            (it, i) =>
              `<li class="palette-item${i === 0 ? ' is-active' : ''}" data-url="${it.u}"><span class="palette-kind">${it.k}</span>${it.t.replace(/</g, '&lt;')}</li>`
          )
          .join('');
      }
      function go(i: number) {
        if (matches[i]) window.location.href = matches[i].u;
      }
      function openPalette() {
        palette.hidden = false;
        document.body.style.overflow = 'hidden';
        input.value = '';
        render();
        input.focus();
      }
      function closePalette() {
        palette.hidden = true;
        document.body.style.overflow = '';
      }
      document.getElementById('palette-btn')?.addEventListener('click', openPalette);
      palette.querySelector('[data-palette-close]')?.addEventListener('click', closePalette);
      input?.addEventListener('input', render);
      results.addEventListener('click', (e) => {
        const li = (e.target as HTMLElement).closest('.palette-item') as HTMLElement;
        if (li) window.location.href = li.dataset.url!;
      });
      input?.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          active = Math.min(active + 1, matches.length - 1);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          active = Math.max(active - 1, 0);
        } else if (e.key === 'Enter') {
          e.preventDefault();
          go(active);
          return;
        } else {
          return;
        }
        results.querySelectorAll('.palette-item').forEach((el, i) =>
          el.classList.toggle('is-active', i === active)
        );
      });

      // ── global keys ───────────────────────────────
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
          e.preventDefault();
          palette.hidden ? openPalette() : closePalette();
        } else if (e.key === 'Escape') {
          if (!modal.hidden) closeVideo();
          if (!palette.hidden) closePalette();
        }
      });
    </script>
  </body>
</html>
